generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

enum LedgerStatus {
  active
  closed
  archived
}

enum PendingActionType {
  delete_recent_expense
  archive_active_ledger
}

model Group {
  id           String            @id @default(cuid())
  name         String
  lineJoinCode String            @unique
  createdAt    DateTime          @default(now())
  members      Member[]
  ledgers      Ledger[]
  expenses     Expense[]
  lineBindings LineChatBinding[]
  pendingActions PendingAction[]
}

model Ledger {
  id         String       @id @default(cuid())
  groupId    String
  name       String
  status     LedgerStatus @default(active)
  creatorLineUserId String?
  isCollectingMembers Boolean @default(false)
  startedAt  DateTime     @default(now())
  endedAt    DateTime?
  archivedAt DateTime?
  isActive   Boolean      @default(false)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  group      Group        @relation(fields: [groupId], references: [id], onDelete: Cascade)
  expenses   Expense[]
  participants LedgerParticipant[]

  @@unique([groupId, name])
  @@index([groupId, isActive])
  @@index([groupId, status, updatedAt])
  @@index([groupId, createdAt])
}

model Member {
  id                   String                @id @default(cuid())
  name                 String
  lineUserId           String?
  paymentSettingsToken String?               @unique
  createdAt            DateTime              @default(now())
  groupId              String
  group                Group                 @relation(fields: [groupId], references: [id], onDelete: Cascade)
  paidExpenses         Expense[]             @relation("ExpensePayer")
  participations       ExpenseParticipant[]
  paymentProfile       MemberPaymentProfile?
  ledgerParticipants   LedgerParticipant[]

  @@unique([groupId, name])
  @@unique([groupId, lineUserId])
  @@index([groupId, createdAt])
}

model MemberPaymentProfile {
  id                 String   @id @default(cuid())
  memberId           String   @unique
  acceptBankTransfer Boolean  @default(false)
  bankName           String?
  bankAccount        String?
  acceptLinePay      Boolean  @default(false)
  linePayId          String?
  acceptCash         Boolean  @default(true)
  paymentNote        String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  member             Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
}

model LineUserProfile {
  id                 String   @id @default(cuid())
  lineUserId         String   @unique
  memberName         String?
  acceptBankTransfer Boolean  @default(false)
  bankName           String?
  bankAccount        String?
  acceptLinePay      Boolean  @default(false)
  acceptCash         Boolean  @default(true)
  paymentNote        String?
  setupState         String?
  setupDraft         Json?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([memberName])
}

model Expense {
  id           String               @id @default(cuid())
  title        String
  notes        String?
  amountCents  Int
  createdAt    DateTime             @default(now())
  groupId      String
  ledgerId     String
  payerId      String
  group        Group                @relation(fields: [groupId], references: [id], onDelete: Cascade)
  ledger       Ledger               @relation(fields: [ledgerId], references: [id], onDelete: Cascade)
  payer        Member               @relation("ExpensePayer", fields: [payerId], references: [id], onDelete: Restrict)
  participants ExpenseParticipant[]

  @@index([groupId, createdAt])
  @@index([ledgerId, createdAt])
  @@index([payerId])
}

model ExpenseParticipant {
  id         String   @id @default(cuid())
  expenseId  String
  memberId   String
  shareCents Int
  createdAt  DateTime @default(now())
  expense    Expense  @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  member     Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([expenseId, memberId])
  @@index([memberId, createdAt])
}

model LedgerParticipant {
  id          String   @id @default(cuid())
  ledgerId     String
  memberId     String
  lineUserId   String?
  displayName  String
  isActive     Boolean  @default(true)
  joinedAt     DateTime @default(now())
  leftAt       DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  ledger       Ledger   @relation(fields: [ledgerId], references: [id], onDelete: Cascade)
  member       Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([ledgerId, memberId])
  @@index([ledgerId, isActive, updatedAt])
  @@index([lineUserId])
}

model PendingAction {
  id                  String            @id @default(cuid())
  groupId             String
  chatId              String
  requesterLineUserId String
  actionType          PendingActionType
  targetExpenseId     String?
  targetLedgerId      String?
  expiresAt           DateTime
  createdAt           DateTime          @default(now())
  group               Group             @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@index([chatId, actionType, expiresAt])
  @@index([groupId, expiresAt])
}

model LineChatBinding {
  id                     String   @id @default(cuid())
  chatId                 String   @unique
  chatType               String
  lineUserId             String?
  groupId                String
  pendingDeleteExpenseId String?
  lastMenuMode           String?
  lastMenuShownAt        DateTime?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  group                  Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@index([groupId, updatedAt])
}
